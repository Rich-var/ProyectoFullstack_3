{
  "info": {
    "_postman_id": "c4a06f8e-52f3-46f3-95e1-85dfb85161ca",
    "name": "Cafeteria Microservicios - DSY1103",
    "description": "Coleccion de pruebas de integracion del ecosistema de microservicios de la cafeteria. Todas las peticiones pasan por el API Gateway (puerto 8080). Ejecutar primero 'Login' para obtener el token JWT; el resto de las carpetas usan Bearer {{token}} automaticamente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (obtener token JWT)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Autentica contra AUTH-SERVICE via Gateway. El script de tests guarda el token en la variable de coleccion {{token}} para que el resto de las peticiones lo usen automaticamente.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"1234\"\n}"
            },
            "auth": {
              "type": "noauth"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login responde 200', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "pm.test('La respuesta contiene un token', function () { pm.expect(data.token).to.be.a('string'); });",
                  "pm.collectionVariables.set('token', data.token);"
                ]
              }
            }
          ]
        }
      ]
    },
